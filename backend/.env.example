# Backend local environment example for Google Calendar OAuth

# Required for backend -> frontend redirects from OAuth callback
FRONTEND_URL=http://localhost:4200

# Google OAuth credentials (create in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match exact Redirect URI in Google OAuth client settings
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/specialist/google/callback/
